{
  "name": "astreintes",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:all",
    "test:all": "npm run test:jest && npm run test:rh-exports",
    "test:rh-calculations": "tsc -p tsconfig.rh-export-tests.json && node out-tsc/rh-export-tests/pages/rh/export-libraries/rh-export-calculations.spec.js",
    "test:rh-interventions": "tsc -p tsconfig.rh-export-tests.json && node out-tsc/rh-export-tests/pages/rh/export-libraries/rh-intervention-calculations.spec.js",
    "test:rh-excel": "tsc -p tsconfig.rh-export-tests.json && node out-tsc/rh-export-tests/pages/rh/export-libraries/rh-excel-export.lib.spec.js",
    "test:rh-word-pdf": "tsc -p tsconfig.rh-export-tests.json && node out-tsc/rh-export-tests/pages/rh/export-libraries/rh-word-pdf-export.lib.spec.js",
    "test:rh-exports": "npm run test:rh-calculations && npm run test:rh-interventions && npm run test:rh-excel && npm run test:rh-word-pdf",
    "test:jest": "jest --runInBand",
    "test:jest:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@angular/animations": "19.2.25",
    "@angular/common": "19.2.25",
    "@angular/compiler": "19.2.25",
    "@angular/core": "19.2.25",
    "@angular/forms": "19.2.25",
    "@angular/platform-browser": "19.2.25",
    "@angular/platform-browser-dynamic": "19.2.25",
    "@angular/router": "19.2.25",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "@primeuix/themes": "^3.0.0",
    "firebase": "^11.2.0",
    "jspdf": "^4.2.1",
    "primeicons": "^8.0.0",
    "primeng": "^19.1.4",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.27",
    "@angular/cli": "19.2.27",
    "@angular/compiler-cli": "19.2.25",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "ts-jest": "^29.4.11",
    "typescript": "~5.8.3"
  }
}
